{
  "meta": {
    "name": "Investment Demo A - Continuity Lens",
    "version": "2.0",
    "description": "Run A: AI interprets company data through a continuity lens => lower perceived risk"
  },
  "circuit": {
    "entry": "node1",
    "nodes": [
      {
        "id": "node1",
        "type": "plugin",
        "resource_ref": {"plugin": "normalize"},
        "inputs": {"raw_text": "state.input.company_text"},
        "outputs": {"normalized_company_text": "state.working.normalized_company_text"}
      },
      {
        "id": "node2",
        "type": "ai",
        "resource_ref": {"prompt": "interpret_continuity", "provider": "gpt_provider"},
        "inputs": {"company_data": "state.working.normalized_company_text"},
        "outputs": {"text": "state.working.analysis.text"}
      },
      {
        "id": "node3",
        "type": "plugin",
        "resource_ref": {"plugin": "score"},
        "inputs": {"analysis_text": "state.working.analysis.text"},
        "outputs": {"score": "state.working.score"}
      },
      {
        "id": "node4",
        "type": "plugin",
        "resource_ref": {"plugin": "decision"},
        "inputs": {"score": "state.working.score"},
        "outputs": {"final_decision": "state.working.final_decision"}
      }
    ],
    "edges": [
      {"from_node": "node1", "to_node": "node2"},
      {"from_node": "node2", "to_node": "node3"},
      {"from_node": "node3", "to_node": "node4"}
    ]
  },
  "resources": {
    "prompts": {
      "interpret_continuity": {
        "template": "You are a financial analyst evaluating a company through the lens of CONTINUITY.\n\nCompany data:\n{{company_data}}\n\nFocus on stable, recurring, and reliable aspects. Describe what signals suggest the business model is continuous and will persist. Keep your answer to 3-4 sentences."
      }
    },
    "providers": {
      "gpt_provider": {
        "type": "openai",
        "model": "gpt-4o-mini",
        "config": {
          "temperature": 0.7,
          "max_output_tokens": 512
        }
      }
    },
    "plugins": {
      "normalize": {
        "entry": "examples.real_ai_bug_autopsy_multinode.plugins.demo_plugins.normalize_company_text"
      },
      "score": {
        "entry": "examples.real_ai_bug_autopsy_multinode.plugins.demo_plugins.score_analysis"
      },
      "decision": {
        "entry": "examples.real_ai_bug_autopsy_multinode.plugins.demo_plugins.make_investment_decision"
      }
    }
  },
  "state": {
    "input": {
      "company_text": "AcmeCorp Q3 2024: Revenue $48M (+12% YoY). Recurring SaaS contracts cover 78% of revenue. Churn rate 3.2%. Management team unchanged for 4 years. New product line launched. Some customer concentration risk with top 3 clients at 35% of revenue."
    },
    "working": {},
    "memory": {}
  },
  "ui": {}
}
