{
  "meta": {
    "name": "investment_analysis",
    "version": "2.0",
    "description": "Investment analysis workflow - complete self-contained savefile"
  },
  "circuit": {
    "entry": "extract_data",
    "nodes": [
      {
        "id": "extract_data",
        "type": "plugin",
        "resource_ref": {
          "plugin": "extract_metrics"
        },
        "inputs": {
          "report": "state.input.quarterly_report"
        },
        "outputs": {
          "revenue": "state.working.metrics.revenue",
          "growth": "state.working.metrics.growth"
        }
      },
      {
        "id": "interpret",
        "type": "ai",
        "resource_ref": {
          "prompt": "interpret_metrics",
          "provider": "test_provider"
        },
        "inputs": {
          "revenue": "state.working.metrics.revenue",
          "growth": "state.working.metrics.growth"
        },
        "outputs": {
          "analysis": "state.working.interpretation"
        }
      },
      {
        "id": "score",
        "type": "plugin",
        "resource_ref": {
          "plugin": "calculate_score"
        },
        "inputs": {
          "revenue": "state.working.metrics.revenue",
          "growth": "state.working.metrics.growth"
        },
        "outputs": {
          "score": "state.working.investment_score"
        }
      },
      {
        "id": "decide",
        "type": "plugin",
        "resource_ref": {
          "plugin": "make_decision"
        },
        "inputs": {
          "score": "state.working.investment_score",
          "threshold": "state.input.threshold"
        },
        "outputs": {
          "decision": "state.working.final_decision"
        }
      }
    ],
    "edges": [
      {
        "from": "extract_data",
        "to": "interpret"
      },
      {
        "from": "extract_data",
        "to": "score"
      },
      {
        "from": "score",
        "to": "decide"
      }
    ]
  },
  "resources": {
    "prompts": {
      "interpret_metrics": {
        "template": "Analyze these financial metrics: Revenue: {revenue}, Growth Rate: {growth}. Provide an investment recommendation."
      }
    },
    "providers": {
      "test_provider": {
        "type": "test",
        "model": "test-model-v1",
        "config": {}
      }
    },
    "plugins": {
      "extract_metrics": {
        "entry": "demo_plugins.extract_metrics"
      },
      "calculate_score": {
        "entry": "demo_plugins.calculate_score"
      },
      "make_decision": {
        "entry": "demo_plugins.make_decision"
      }
    }
  },
  "state": {
    "input": {
      "quarterly_report": {
        "revenue": 1000000,
        "growth_rate": 0.15
      },
      "threshold": 70
    },
    "working": {},
    "memory": {}
  },
  "ui": {
    "layout": {
      "nodes": {
        "extract_data": {"x": 100, "y": 100},
        "interpret": {"x": 300, "y": 50},
        "score": {"x": 300, "y": 150},
        "decide": {"x": 500, "y": 100}
      }
    },
    "metadata": {
      "editor_version": "1.0",
      "zoom_level": 1.0
    }
  }
}
